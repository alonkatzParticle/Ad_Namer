# ─────────────────────────────────────────────────────────────────────────────
#  Ad Namer – Environment Configuration
#  Copy this file to .env and fill in VITE_MONDAY_API_KEY.
#  All other values are pre-filled with the correct defaults for your account.
# ─────────────────────────────────────────────────────────────────────────────

# Monday.com personal API token
# Get yours at: Profile picture → Developers → My Access Tokens → "New Token"
VITE_MONDAY_API_KEY=your_monday_api_key_here

# Set to "true" to disable ALL write operations (e.g. staging / demo environments).
# When true the "Save to Task" button is hidden and all mutations are blocked.
VITE_READ_MODE=false

# ── Board IDs ─────────────────────────────────────────────────────────────────
VITE_VIDEO_BOARD_ID=5433027071
VITE_DESIGN_BOARD_ID=8036329818

# ── Column IDs (verified against live board structure) ────────────────────────
# Assignee — both boards use the same column id
VITE_ASSIGNEE_COLUMN_ID=people

# Ad Name text column — Video board only
VITE_AD_NAME_COLUMN_ID=text_mm1fn440

# Type/category status column — Video board
VITE_VIDEO_TYPE_COLUMN_ID=label4

# Type/category status column — Design board
VITE_DESIGN_TYPE_COLUMN_ID=status_1__1

# Product/Bundle column — both boards use the same column id
VITE_PRODUCT_COLUMN_ID=label9
